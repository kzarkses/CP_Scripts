desc: CP_Goniometer_JSFX
author: Vladimir Belov (modified by Cedric Pelletier)
version: 1.1

options:gmem=CP_Goniometer, no_meter

in_pin:left input
in_pin:right input
out_pin:none

@init
gmem_offset = 1000;
buffer_size = 4096;
buffer_mask = buffer_size - 1;  // for & instead of %
write_pos = 0;

// Downsample writes to gmem: target ~12 kpoints/sec (enough for 1024 visible at 60fps)
write_decim = max(1, floor(srate / 12000));
decim_counter = 0;

@sample

// Mid-side encoding for goniometer (L-R, L+R)
Lr = spl0 - spl1;
Rr = spl0 + spl1;

decim_counter += 1;
decim_counter >= write_decim ? (
  decim_counter = 0;
  base = gmem_offset + write_pos * 2;
  gmem[base] = Lr;
  gmem[base + 1] = Rr;
  write_pos = (write_pos + 1) & buffer_mask;
  gmem[gmem_offset - 1] = write_pos;
);
